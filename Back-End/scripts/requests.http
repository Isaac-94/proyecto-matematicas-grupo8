@baseUrl = http://localhost:3001/api
@usuarioId = user-001
@adminId = admin-001
@token = dev-bypass-token

###
# 1. Chequear Salud del Server
GET {{baseUrl}}/health

###
# 2. Obtener Secciones (en Mock inyecta user-001 por defecto)
GET {{baseUrl}}/secciones?usuarioId={{usuarioId}}
Authorization: Bearer {{token}}

###
# 3. Registro / Sincronización de Usuario
# En MOCK se crea un usuario en memoria volátil.
POST {{baseUrl}}/usuarios/registro
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "uid": "test-user-999",
    "email": "tester@innovalab.com",
    "nombre": "Usuario de Prueba"
}

###
# 4. Ver Escenarios de una Sección (Ej: Economía Doméstica ID: 1)
GET {{baseUrl}}/secciones/1/escenarios

###
# 5. Registrar Progreso - RESPUESTA INCORRECTA (Gatilla Gemini tiene demora)
POST {{baseUrl}}/progreso
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "usuarioId": "test-user-999",
    "escenarioId": 1,
    "opcionId": 1
}

###
# 6. Registrar Progreso - RESPUESTA CORRECTA (Suma Tk)
POST {{baseUrl}}/progreso
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "usuarioId": "test-user-999",
    "escenarioId": 1,
    "opcionId": 2
}

###
# 7. CRUD - Crear nueva Sección (Admin)
POST {{baseUrl}}/secciones
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "nombre": "Álgebra Lineal",
    "descripcion": "Introducción a matrices",
    "grado": 3,
    "puntosRequeridos": 50,
    "puntosRecompensa": 100,
    "umbralAprobacion": 0.8,
    "adminId": "{{adminId}}"
}

###
# 8. CRUD - Editar Sección Existente
PUT {{baseUrl}}/secciones/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "nombre": "Economía del Hogar (Editado)",
    "descripcion": "Gestión de gastos",
    "grado": 1,
    "umbralAprobacion": 0.5,
    "puntosRecompensa": 20,
    "puntosRequeridos": 0,
    "adminId": "{{adminId}}"
}

###
# 9. CRUD - Eliminar Escenario (Cuidado, en MOCK se borra del array en RAM)
DELETE {{baseUrl}}/secciones/1/escenarios/1
Content-Type: application/json
Authorization: Bearer {{token}}

{"adminId": "{{adminId}}"}

###
# 10. Ver Logs de Auditoría (CSV local)
GET {{baseUrl}}/logs
Authorization: Bearer {{token}}
